# Points threshold for the Algolia "points>X" filter
POINTS_THRESHOLD=300

# How many of the most-recent above-threshold stories to process per run
STORY_LIMIT=40

# How often to run the scrape (milliseconds). Default: hourly.
SCRAPE_INTERVAL_MS=3600000

# How long to keep stories (days) before purging.
RETENTION_DAYS=7

# HTTP server port and bind address (LAN-only by default; 0.0.0.0 to expose on LAN).
PORT=8089
HOST=0.0.0.0

# SQLite database file path (relative to project root or absolute).
DB_PATH=data/hnkobo.db

# Per-article fetch timeout (ms) and max concurrent article fetches.
ARTICLE_TIMEOUT_MS=15000
ARTICLE_CONCURRENCY=4

# Run a scrape immediately on server startup (true/false).
SCRAPE_ON_START=true
